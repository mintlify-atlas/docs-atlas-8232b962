  "keyFeatures": [
    "Monorepo architecture with Turborepo and Bun",
    "End-to-end type safety with Hono RPC",
    "Next.js 16 frontend with React 19",
    "Hono backend API with OpenAPI documentation",
    "PostgreSQL database with Drizzle ORM",
    "Better Auth authentication with OAuth providers",
    "Shadcn UI components with Tailwind CSS",
    "PostHog analytics integration",
    "Docker and Vercel deployment support"
  ],
  "publicApiSurface": [
    "GET /api/health - Health check endpoint",
    "GET /api/v1/session - Get current session",
    "GET /api/v1/user - Get current user",
    "POST /api/auth/sign-in - Sign in endpoint",
    "POST /api/auth/sign-up - Sign up endpoint",
    "apiClient - Type-safe API client for frontend"
